  style.stroke: "#06b6d4"
  style.stroke-dash: 3
}
backends.adapters -> backends.perception-backends: routes to {
  style.stroke: "#6b7280"
  style.stroke-dash: 3
}
backends.adapters -> backends.action: routes to {
  style.stroke: "#6b7280"
  style.stroke-dash: 3
}

# ─── MCP CONNECTION ───
mcp -> cognitive.imagination.next-state: task {
  style.stroke: "#4a90d9"
}
cognitive.motor -> mcp: results {
  style.stroke: "#4a90d9"
  style.stroke-dash: 5
}

# ─── TIERED PERCEPTION ───
tiers: TIERED PERCEPTION {
  style: {
    fill: "#1a1a2e"
    stroke: "#8b5cf6"
    font-color: "#c4b5fd"
    border-radius: 10
  }

  t0: "T0 Reflex — 0 tokens" {
    style.fill: "#1e1e3a"
    style.stroke: "#4ade80"
    style.font-color: "#e8e8e8"
    style.border-radius: 6
  }
  t1: "T1 Glance — 500 tokens" {
    style.fill: "#1e1e3a"
    style.stroke: "#facc15"
    style.font-color: "#e8e8e8"
    style.border-radius: 6
  }
  t2: "T2 Look — 2K tokens" {
    style.fill: "#1e1e3a"
    style.stroke: "#f97316"
    style.font-color: "#e8e8e8"
    style.border-radius: 6
  }
  t3: "T3 Study — 5K tokens" {
    style.fill: "#1e1e3a"
    style.stroke: "#ef4444"
    style.font-color: "#e8e8e8"
    style.border-radius: 6
  }

  t0 -> t1 -> t2 -> t3: escalate on surprise {
    style.stroke: "#8b5cf6"
    style.stroke-dash: 3
  }
}

cognitive.imagination.diff -> tiers: prediction error selects tier {
  style.stroke: "#8b5cf6"
  style.stroke-dash: 5
}

