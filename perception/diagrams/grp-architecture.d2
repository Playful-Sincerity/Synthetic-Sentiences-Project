direction: down

# ─── TITLE ───
title: |md
  # GRP
  **Generative Reconciliation Perception**
  Imagine. Observe. Reconcile. Act.
| {
  style: {
    font-color: "#c8d6e5"
    fill: "#0a0a1a"
    stroke: "#2d3436"
    border-radius: 12
  }
}

# ─── EXTERNAL INTERFACE ───
parent-being: Parent Being (Claude Code / PD) {
  style: {
    fill: "#1a1a2e"
    stroke: "#d4a574"
    font-color: "#d4a574"
    border-radius: 8
    bold: true
  }
}

mcp: MCP Server {
  style: {
    fill: "#16213e"
    stroke: "#4a90d9"
    font-color: "#e8e8e8"
    border-radius: 8
  }
}

cli: CLI {
  style: {
    fill: "#16213e"
    stroke: "#4a90d9"
    font-color: "#e8e8e8"
    border-radius: 8
  }
}

parent-being -> mcp: task / goal {
  style.stroke: "#d4a574"
}
mcp -> parent-being: files in sandbox {
  style.stroke: "#d4a574"
  style.stroke-dash: 5
}
cli -> mcp: direct invoke {
  style.stroke: "#4a90d9"
  style.stroke-dash: 3
}

# ─── THE COGNITIVE LOOP ───
cognitive: COGNITIVE CORE {
  style: {
    fill: "#0d1117"
    stroke: "#58a6ff"
    font-color: "#58a6ff"
    border-radius: 12
    bold: true
  }

  # ─── IMAGINATION ENGINE ───
  imagination: "IMAGINATION ENGINE" {
    style: {
      fill: "#1a1130"
      stroke: "#a855f7"
      font-color: "#c4b5fd"
      border-radius: 10
      bold: true
    }

    next-state: |md
      **NEXT-STATE**
      Generate expected next state
      _"What should happen if I act?"_
    | {
      style: {
        fill: "#2d1b4e"
        stroke: "#a855f7"
        font-color: "#e8e8e8"
        border-radius: 8
      }
    }

    end-state: |md
      **END-STATE**
      Imagine final state or video
      _"What should it look like at the end?"_
    | {
      style: {
        fill: "#3a1d68"
        stroke: "#c084fc"
        font-color: "#ffffff"
        border-radius: 8
        bold: true
      }
    }

    diff: |md
      **DIFF**
      Prediction error
      _imagination vs reality_
    | {
      style: {
        fill: "#2d1b4e"
        stroke: "#a855f7"
        font-color: "#e8e8e8"
        border-radius: 8
      }
    }
  }

  # ─── DUAL PERCEPTION ───
  perception: "DUAL PERCEPTION" {
    style: {
      fill: "#0d1f0d"
      stroke: "#22c55e"
      font-color: "#86efac"
      border-radius: 10
      bold: true
    }

    visual: |md
      **VISUAL CORTEX**
      Screenshot + SoM
      Layout, colors, spatial
    | {
      style: {
        fill: "#1a2e1a"
        stroke: "#22c55e"
        font-color: "#e8e8e8"
        border-radius: 8
      }
    }

    analytical: |md
      **ANALYTICAL CORTEX**
      DOM / a11y / macOS AX
      Structure, state, handlers
    | {
      style: {
        fill: "#1a2e1a"
        stroke: "#22c55e"
        font-color: "#e8e8e8"
        border-radius: 8
      }
    }

    reconciler: |md
      **RECONCILER (collaborative)**
      Merge dual views
      Disagreement = information
      _imagined and observed converge_
    | {
      style: {
        fill: "#0f3d0f"
        stroke: "#4ade80"
        font-color: "#ffffff"
        border-radius: 8
        bold: true
      }
    }

    visual -> reconciler: visual perception {
      style.stroke: "#22c55e"
    }
    analytical -> reconciler: structural perception {
      style.stroke: "#22c55e"
    }
  }

  # ─── ACTION PIPELINE ───
  affordances: |md
    **AFFORDANCES**
    Elements as action potentials
    _"What can I DO here?"_
  | {
    style: {
      fill: "#1e293b"
      stroke: "#f59e0b"
      font-color: "#fcd34d"
      border-radius: 8
    }
  }

  reverse-engineer: |md
    **REVERSE-ENGINEER**
    End-state → action sequence
    Code or motor commands
  | {
    style: {
      fill: "#3a2412"
      stroke: "#fb923c"
      font-color: "#ffffff"
      border-radius: 8
      bold: true
    }
  }

  planner: |md
    **PLANNER**
    Spreading activation through MWM
    Goal → relevant actions
  | {
    style: {
      fill: "#1e293b"
      stroke: "#f59e0b"
      font-color: "#e8e8e8"
      border-radius: 8
    }
  }

  # ─── SECURITY ───
  security: SECURITY {
    style: {
      fill: "#1a0a0a"
      stroke: "#ef4444"
      font-color: "#fca5a5"
      border-radius: 10
      bold: true
    }

    critic: |md
      **ALIGNMENT CRITIC**
      Haiku on every action
      _"Does this serve the intent?"_
    | {
      style: {
        fill: "#2d1212"
        stroke: "#ef4444"
        font-color: "#e8e8e8"
        border-radius: 8
      }
    }

    guard: |md
      **SECURITY MEMBRANE**
      Content isolation
      HTTP sandbox
      Credential vault
    | {
      style: {
        fill: "#2d1212"
        stroke: "#ef4444"
        font-color: "#e8e8e8"
        border-radius: 8
      }
    }

    critic -> guard: validated {
      style.stroke: "#ef4444"
    }
  }

  # ─── MOTOR SYSTEM ───
  motor: |md
    **MOTOR SYSTEM**
    Bezier mouse · Gaussian typing
    Momentum scroll · Human-like
  | {
    style: {
      fill: "#1e293b"
      stroke: "#06b6d4"
      font-color: "#e8e8e8"
      border-radius: 8
    }
  }

  # ─── COGNITIVE FLOW ───
  imagination.next-state -> perception.reconciler: observe reality {
    style.stroke: "#a855f7"
    style.stroke-dash: 3
  }
  imagination.end-state -> reverse-engineer: target {
    style.stroke: "#c084fc"
  }
  perception.reconciler -> imagination.diff: page model {
    style.stroke: "#22c55e"
  }
  imagination.diff -> affordances: prediction error {
    style.stroke: "#a855f7"
  }
  reverse-engineer -> planner: action sequence {
    style.stroke: "#fb923c"
  }
  affordances -> planner: action potentials {
    style.stroke: "#f59e0b"
  }
  planner -> security.critic: intended action {
    style.stroke: "#f59e0b"
  }
  security.guard -> motor: safe action {
    style.stroke: "#ef4444"
  }
}

# ─── MWM (sibling repo, world model substrate) ───
mwm: "MWM — Memory as World Model" {
  style: {
    fill: "#0a1628"
    stroke: "#3b82f6"
    font-color: "#93c5fd"
    border-radius: 10
    bold: true
  }

  graph: |md
    **Interpretable Graph**
    (sibling repo, separate substrate)
    Site patterns · Causal edges
    Spreading activation
    Reconsolidation on surprise
  | {
    style: {
      fill: "#1e3a5f"
      stroke: "#3b82f6"
      font-color: "#e8e8e8"
      border-radius: 8
    }
  }
}

# ─── LEARN LOOP ───
cognitive.motor -> mwm: prediction error → reconsolidate {
  style.stroke: "#3b82f6"
  style.stroke-dash: 5
  style.animated: true
}
mwm -> cognitive.imagination.next-state: priors + expectations {
  style.stroke: "#3b82f6"
  style.stroke-dash: 5
  style.animated: true
}
mwm -> cognitive.imagination.end-state: learned targets {
  style.stroke: "#3b82f6"
  style.stroke-dash: 5
  style.animated: true
}

