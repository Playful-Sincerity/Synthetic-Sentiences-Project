    pw-a11y: Playwright a11y {
      style.fill: "#1a2e1a"
      style.stroke: "#22c55e"
      style.font-color: "#e8e8e8"
      style.border-radius: 6
    }
  }

  action: Action {
    style: {
      fill: "#1e293b"
      stroke: "#06b6d4"
      font-color: "#67e8f9"
      border-radius: 8
    }

    playwright: Playwright / Patchright {
      style.fill: "#0a2530"
      style.stroke: "#06b6d4"
      style.font-color: "#e8e8e8"
      style.border-radius: 6
    }
    camoufox: Camoufox {
      style.fill: "#0a2530"
      style.stroke: "#06b6d4"
      style.font-color: "#e8e8e8"
      style.border-radius: 6
    }
    pyautogui: PyAutoGUI {
      style.fill: "#0a2530"
      style.stroke: "#06b6d4"
      style.font-color: "#e8e8e8"
      style.border-radius: 6
    }
    macos: macOS AX {
      style.fill: "#0a2530"
      style.stroke: "#06b6d4"
      style.font-color: "#e8e8e8"
      style.border-radius: 6
    }
  }

  adapters: Adapters {
    style: {
      fill: "#1e293b"
      stroke: "#6b7280"
      font-color: "#d1d5db"
      border-radius: 8
    }

    browser: Browser {
      style.fill: "#2d3748"
      style.stroke: "#9ca3af"
      style.font-color: "#e8e8e8"
      style.border-radius: 6
    }
    desktop: Desktop {
      style.fill: "#2d3748"
      style.stroke: "#9ca3af"
      style.font-color: "#e8e8e8"
      style.border-radius: 6
    }
    screen: Any Window {
      style.fill: "#2d3748"
      style.stroke: "#9ca3af"
      style.font-color: "#e8e8e8"
      style.border-radius: 6
    }
  }
}

# ─── BACKEND CONNECTIONS ───
cognitive.perception.visual -> backends.perception-backends: screenshot {
  style.stroke: "#22c55e"
  style.stroke-dash: 3
}
cognitive.perception.analytical -> backends.perception-backends: structure {
  style.stroke: "#22c55e"
  style.stroke-dash: 3
}
