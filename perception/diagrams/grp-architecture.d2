# ─── SANDBOX ───
sandbox: "~/.grp/workspace/" {
  shape: cylinder
  style: {
    fill: "#2d1212"
    stroke: "#ef4444"
    font-color: "#fca5a5"
    border-radius: 8
  }
}

cognitive.motor -> sandbox: screenshots + findings {
  style.stroke: "#ef4444"
  style.stroke-dash: 3
}
sandbox -> parent-being: read results {
  style.stroke: "#d4a574"
  style.stroke-dash: 5
}
